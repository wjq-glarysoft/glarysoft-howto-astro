---
import lottie from "../../public/js/lottie"
---
<div class="header-wrap">
	<div class="header">
        <div class="headcon clearfix">
            <div class="logo">
                <a href="/"><img src="/img/logo.png" alt="glarysoft" /></a>
            </div>
            <div class="header-r" role="navigation">
                <div class="translate-nor"><div id="google_translate_element"></div></div>
                <ul class="nav">
                    <li id="products"><button class="arrow">Products</button>            	
                        <div class="subnavpart">
                            <div class="subnav">
                                <a href="/glary-utilities/" class="notranslate" target="_self">Glary Utilities</a>
                                <a href="/malware-hunter/" class="notranslate" target="_self">Malware Hunter</a> 
                                <a href="/file-recovery-free/" class="notranslate" target="_self">File Recovery</a>
                                <a href="/software-update-free/" class="notranslate" target="_self">Software Update</a>
                            </div>   
                        </div>
                    </li>
                    <li id="downloads"><button class="arrow">Downloads</button>
                        <div class="subnavpart">
                            <div class="subnav">
                                <a href="/downloads/?p=gu-page" target="_self">Download <span class="notranslate">Glary Utilities</span></a>
                                <a href="/downloads/?p=mh-page" target="_self">Download <span class="notranslate">Malware Hunter</span></a>
                                <a href="/downloads/?p=fr-page" target="_self">Download <span class="notranslate">File Recovery</span></a> 
                                <a href="/downloads/?p=su-page" target="_self">Download <span class="notranslate">Software Update</span></a>
                            </div>   
                        </div>  
                    </li>
                    <li id="shop">                  
                    <a href="/store/" target="_self">
                        <p id="store-wrap"><span id="store"></span></p>
                    Store</a>
                    </li>
                    <li id="support"><button class="arrow">Support</button>
                        <div class="subnavpart">
                            <div class="subnav">
                                <a href="/support/lost-license/" target="_self">Lost License</a>
                                <a href="https://www.glarysoft.com/kb/faqs/" target="_self">FAQs</a>
                                <a href="/support/online-feedback/" target="_self">Online Feedback</a>
                                <a href="https://my.glarysoft.com/" target="_self">My Account</a>                    
                            </div>
                        </div>
                    </li>
                    <li id="company"><button class="arrow">Company</button>
                        <div class="subnavpart">
                            <div class="subnav">
                                <a href="/company/about-us/" target="_self">About Us</a>
                                <a href="/company/press-release/" target="_self">Press Center</a>
                                <a href="/company/partners/" target="_self">Reseller</a>
                                <a href="/company/affiliate/" target="_self">Affiliate</a>
                                <a href="/company/contact-us/" target="_self">Contact Us</a>
                            </div>
                        </div>
                    </li>
                </ul> 
            </div>
            <div class="navshortcut" role="button" tabindex="0"></div>
        </div>
    </div>
</div> 

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    
    // ==================== Google Translate ====================
    let translateInterval = null;
    
    function fixTranslateDisplay() {
      const translateElement = document.querySelector('.goog-te-gadget-simple');
      if (!translateElement) return false;

      const firstSpan = translateElement.querySelector('span a span:first-child');
      if (firstSpan) {
        const currentText = firstSpan.textContent || firstSpan.innerHTML;
        if (currentText === 'Select Language' || currentText.trim() === '') {
          firstSpan.textContent = 'English';
        }
      }

      const translateContainer = document.getElementById('google_translate_element');
      if (translateContainer) {
        translateContainer.style.visibility = 'visible';
      }

      if (translateInterval) {
        clearInterval(translateInterval);
        translateInterval = null;
      }

      return true;
    }

    function initTranslate() {
      if (fixTranslateDisplay()) return;
      
      translateInterval = setInterval(() => {
        if (fixTranslateDisplay()) {
          clearInterval(translateInterval);
          translateInterval = null;
        }
      }, 50);
    }

    // ==================== 汉堡菜单 ====================
    function initHamburgerMenu() {
      const shortcut = document.querySelector('.navshortcut');
      const headerR = document.querySelector('.header-r');
      
      if (!shortcut || !headerR) return;

      const toggleMenu = (e) => {
        if (e) e.stopPropagation();
        headerR.classList.toggle('active');
        shortcut.setAttribute('aria-expanded', headerR.classList.contains('active'));
      };

      shortcut.addEventListener('click', toggleMenu);
      
      shortcut.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          toggleMenu(e);
        }
      });

      document.addEventListener('click', (e) => {
        if (!e.target.closest('.header-r') && !e.target.closest('.navshortcut')) {
          headerR.classList.remove('active');
          shortcut.setAttribute('aria-expanded', 'false');
        }
      });
    }

    // ==================== 导航菜单 ====================
    function initNavigation() {
      const isAndroid = navigator.userAgent.toLowerCase().includes('android');
      const navItems = document.querySelectorAll('.nav > li');

      navItems.forEach((li) => {
        const subnavPart = li.querySelector('.subnavpart');
        if (!subnavPart) return;

        const trigger = li.querySelector('a, button');
        const arrow = li.querySelector('.arrow');

        if (isAndroid && trigger) {
          trigger.addEventListener('click', function(e) {
            e.preventDefault();
            this.classList.toggle('active');
            subnavPart.style.display = this.classList.contains('active') ? 'block' : 'none';
          });
        } else if (!isAndroid) {
          li.addEventListener('mouseenter', () => {
            if (arrow) arrow.classList.add('active');
            subnavPart.style.display = 'block';
          });
          
          li.addEventListener('mouseleave', () => {
            if (arrow) arrow.classList.remove('active');
            subnavPart.style.display = 'none';
          });
        }
      });
    }

    // ==================== Store 功能 ====================
    function initStore() {
      // Store 动画
      function storeIcon() {
        const container = document.getElementById('store');
        if (!container || typeof lottie === 'undefined') return;

        try {
          const anim = lottie.loadAnimation({
            container: container,
            renderer: 'svg',
            loop: false,
            autoplay: true,
            path: '/js/buy.json',
            name: 'store',
          });
          
          anim.addEventListener('enterFrame', function(e) {
            if (e.currentTime === 15) {
              const storeWrap = document.getElementById('store-wrap');
              if (storeWrap) storeWrap.style.visibility = 'visible';
              anim.removeEventListener('enterFrame');
            }
          });
        } catch (e) {
          console.warn('Store animation error:', e);
        }
      }

      // Store hover
      function initStoreHover() {
        const shopLink = document.querySelector('.nav > li#shop > a');
        if (!shopLink) return;

        shopLink.addEventListener('mouseover', function(e) {
          if (e.target === e.currentTarget) {
            const storeWrap = document.getElementById('store-wrap');
            const store = document.getElementById('store');
            
            if (storeWrap) storeWrap.style.background = 'none';
            if (store) store.style.visibility = 'visible';
            
            if (typeof lottie !== 'undefined') {
              try {
                lottie.stop('store');
                lottie.play('store');
              } catch (e) {}
            }
          }
        });
      }

      storeIcon();
      initStoreHover();
    }

    // ==================== 启动所有功能 ====================
    function initAll() {
      // 清理旧的定时器
      if (translateInterval) {
        clearInterval(translateInterval);
        translateInterval = null;
      }
      
      initTranslate();
      initHamburgerMenu();
      initNavigation();
      initStore();
    }

    // 页面加载完成后初始化
    if (document.readyState === 'complete') {
      initAll();
    } else {
      window.addEventListener('load', initAll);
    }

    // Astro View Transitions 支持
    document.addEventListener('astro:page-load', initAll);
  });
</script>