    jQuery(window).resize(function(){	
      var widgetW = jQuery("#webWidget").outerWidth(true);
      var widgetH = jQuery("#webWidget").outerHeight(true);
      if(widgetW>0){
        zE('webWidget', 'updateSettings', {
          webWidget: {
            offset: {
              horizontal: (jQuery(window).width() - widgetW) / 2,
              vertical: jQuery(window).height()>=widgetH?(jQuery(window).height() - widgetH) / 2:0
            }
          }
        })
      }        
    })  
    zE("webWidget", "hide");
    function openWidget() {
      zE("webWidget", "show");
      zE("webWidget", "open");        
    }
    zE("webWidget:on", "close", function () {
      zE("webWidget", "hide");
    });    
    zE('webWidget:on', 'open', function() {  
      if(!isMobile()){  
        if(jQuery("#webWidget").outerWidth(true) == null){  
          var s = setInterval(function(){
            if(jQuery("#webWidget").outerWidth(true)>0){            
              clearInterval(s);
              jQuery("#webWidget").addClass("widget-pc");
              var widgetW = jQuery("#webWidget").outerWidth(true);
              var widgetH = jQuery("#webWidget").outerHeight(true);
              zE('webWidget', 'updateSettings', {
                webWidget: {
                  offset: {
                    horizontal: (jQuery(window).width() - widgetW) / 2,
                    vertical: jQuery(window).height()>=widgetH?(jQuery(window).height() - widgetH) / 2:0
                  }
                }
              })
            }          
          },50)        
        } 
        else{
          jQuery("#webWidget").addClass("widget-pc");
          var widgetW = jQuery("#webWidget").outerWidth(true);
          var widgetH = jQuery("#webWidget").outerHeight(true);
          zE('webWidget', 'updateSettings', {
            webWidget: {
              offset: {
                horizontal: (jQuery(window).width() - widgetW) / 2,
                vertical: jQuery(window).height()>=widgetH?(jQuery(window).height() - widgetH) / 2:0
              }
            }
          })
        }   
      }              
    });   
