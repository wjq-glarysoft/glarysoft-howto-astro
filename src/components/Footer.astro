<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const cookiesTip = document.querySelector('.cookiesTip');
    if (!cookiesTip) return;
    
    const hasAccepted = (() => {
      if (window.localStorage) {
        return !!window.localStorage.getItem('ckTip');
      }
      return document.cookie.split('; ').some(row => row.startsWith('ckTip='));
    })();

    
    if (!hasAccepted) {
      cookiesTip.style.display = 'block';
    }
    
    const acceptBtn = document.getElementById('removeCkBtn');
    if (acceptBtn) {
      acceptBtn.addEventListener('click', () => {
        if (window.localStorage) {
          window.localStorage.setItem('ckTip', 'true');
        }
        document.cookie = 'ckTip=true; max-age=31536000; path=/';
        cookiesTip.style.display = 'none';
      });
    }


    const subscribeBtn = document.getElementById('subscribe');
    const subscribeEmail = document.getElementById('subscribe_email');
    const subscribeTip = document.getElementById('subscribe_tip');
    
    if (!subscribeBtn || !subscribeEmail || !subscribeTip) return;

    let subscribeTimer = null;

    function showTip(message, className = '') {
      
      if (subscribeTimer) {
        clearTimeout(subscribeTimer);
        subscribeTimer = null;
      }

      subscribeTip.className = className;
      subscribeTip.textContent = message;
      subscribeTip.style.display = 'block';

      subscribeTimer = setTimeout(() => {
        subscribeTip.style.display = 'none';
        subscribeTimer = null;
      }, 30000);
    }

    function handleSubscribe(e) {
      e.preventDefault();

      
      if (subscribeTimer) {
        clearTimeout(subscribeTimer);
        subscribeTimer = null;
      }

      subscribeTip.style.display = 'none';

      const subEmail = subscribeEmail.value.trim();

      // 验证邮箱
      const emailRegex = /^\w+([-+.']\w+)*@\w+([-.]\w+)*\.\w+([-.]\w+)*$/;
      if (subEmail.length === 0 || !emailRegex.test(subEmail)) {
        showTip('Enter valid e-mail', 'fail');
        return;
      }

      // 发送 AJAX 请求
      const xhr = new XMLHttpRequest();
      xhr.open('POST', '/subscribe/verify.php', true);
      xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
      
      xhr.onreadystatechange = function() {
        if (xhr.readyState === 4) {
          if (xhr.status === 200) {
            const msg = xhr.responseText.trim();
            
            if (msg === '1') {
              showTip('Thank you! Please check your email and confirm your subscription!', '');
            } else if (msg === '2' || msg === '4') {
              showTip('Failed, please try again', 'fail');
            } else {
              showTip('Frequent operation, you can try again after half an hour', 'info');
            }
          } else {
            showTip('Network error, please try again', 'fail');
          }
        }
      };

      xhr.onerror = () => showTip('Network error, please try again', 'fail');
      xhr.send('useremail=' + encodeURIComponent(subEmail));
    }

    // 绑定事件
    subscribeBtn.addEventListener('click', handleSubscribe);
    
    // 回车提交
    subscribeEmail.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        handleSubscribe(e);
      }
    });
  });
</script>

