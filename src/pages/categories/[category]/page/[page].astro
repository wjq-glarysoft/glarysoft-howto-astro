---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getExcerpt } from '../../../../utils/truncate';
import Pagination from '../../../../components/Pagination.astro';

// 辅助函数
export function formatCategoryName(slug: string): string {
  const categoryMap: Record<string, string> = {
    'system-tools': 'System & Tools',
    'files-folders': 'Files & Folders',
    'clean-up-repair': 'Clean Up & Repair',
    'optimize-improve': 'Optimize & Improve',
    'privacy-security': 'Privacy & Security'
  };
  
  return categoryMap[slug] || 
    slug.split('-')
      .map(word => word.charAt(0).toUpperCase() + word.slice(1))
      .join(' & ');
}

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric'
  });
}

// 生成所有分页路径
export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const POSTS_PER_PAGE = 9;

  // 获取所有唯一分类
  const allCategories = [...new Set(
    allPosts.flatMap(post => post.data.categories || [])
  )];
  
  const paths = [];
  
  // 为每个分类生成分页路径
  for (const category of allCategories) {
    // 获取该分类的所有文章
    const categoryPosts = allPosts
      .filter(post => post.data.categories?.includes(category))
      .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
    
    // 计算总页数
    const totalPages = Math.ceil(categoryPosts.length / POSTS_PER_PAGE);
    
    // 生成第2页到最后一页（第1页由 [cat].astro 处理）
    for (let page = 2; page <= totalPages; page++) {
      paths.push({
        params: { 
          category: category,
          page: String(page)
        },
        props: { 
          categorySlug: category,
          currentPage: page,
          totalPages,
          categoryPosts
        }
      });
    }
  }
  
  return paths;
}

// 接收参数
const { categorySlug, currentPage, totalPages, categoryPosts } = Astro.props;
const categoryName = formatCategoryName(categorySlug);


---

<BaseLayout title={`${categoryName} - Page ${currentPage} - Glarysoft How-to Articles`}>
  <div class="container" style="margin-top: 1.2rem;">
    <div>
      <p class="block-spacer-50"></p>
      <h1 class="x-large-font-size">Category: {categoryName}</h1>
      <p class="block-spacer-30"></p>
    </div>
    
    <ul class="is-layout-grid is-layout-grid-3">
      {categoryPosts.map(post => (
        <li>
          <div class="post-card">
            <h2>
              <a href={`/posts/${post.data.slug}/`}>{post.data.title}</a>
            </h2>
            <div>
              <div class="post-meta">
                <span>{formatDate(post.data.date)}</span> — by 
                <a href={`/author/${post.data.author?.toLowerCase().replace(/\s+/g, '-')}/`}>
                  {post.data.author}
                </a> in 
                <a href={`/categories/${categorySlug}/`}>{categoryName}</a>
              </div>
              <div>
                <p class="post-excerpt">
                  {getExcerpt(post.body ?? "", 55)}
                </p>
                <p style="margin-top: 1.2rem;">
                  <a href={`/posts/${post.data.slug}`}>read more</a>
                </p>
              </div>
            </div>
          </div>
        </li>
      ))}
    </ul>
    
    <Pagination 
      currentPage={currentPage} 
      totalPages={totalPages} 
      baseUrl={`/categories/${categorySlug}/page/`}
    />
  </div>
</BaseLayout>