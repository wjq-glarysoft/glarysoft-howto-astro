---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getExcerpt } from '../../utils/truncate';
import Pagination from '../../components/Pagination.astro';

const POSTS_PER_PAGE = 9;

export function formatCategoryName(slug: string): string {
  const categoryMap: Record<string, string> = {
    'system-tools': 'System & Tools',
    'files-folders': 'Files & Folders',
    'clean-up-repair': 'Clean Up & Repair',
    'optimize-improve': 'Optimize & Improve',
    'privacy-security': 'Privacy & Security'
  };
  
  return categoryMap[slug] || 
    slug.split('-')
      .map(word => word.charAt(0).toUpperCase() + word.slice(1))
      .join(' & ');
}


// 生成所有分类的首页路径
export async function getStaticPaths() {
  const allPosts = await getCollection('posts');

  // 从文章的categories字段获取所有不重复的分类
  const allCategories = [...new Set(
    allPosts.flatMap(post => post.data.categories || [])
  )];

  // 为每个分类生成首页路径数组
  return Array.from(allCategories).map(category => ({
    params: { cat: encodeURIComponent(category) },
    props: { 
        categorySlug: category,
        categoryName:formatCategoryName(category),
        allPosts
    }
  }));
}

// 接收参数
const { categorySlug,categoryName, allPosts } = Astro.props;

// 获取该分类的所有文章
const categoryPosts = allPosts
  .filter(post => post.data.categories?.includes(categorySlug))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// 计算分页信息
const totalPages = Math.ceil(categoryPosts.length / POSTS_PER_PAGE);
const currentPage = 1;
const startIndex = 0;
const currentPosts = categoryPosts.slice(startIndex, startIndex + POSTS_PER_PAGE);


// 格式化日期函数
function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric'
  });
}
---

<BaseLayout title={`${categoryName} - Glarysoft How-to Articles`}>
    <div class="container" style="margin-top: 1.2rem;">
        <div>
            <p class="block-spacer-50"></p>
            <h1 class="x-large-font-size">Category: {categoryName}</h1>
            <p class="block-spacer-30"></p>
        </div>        
        <ul class="is-layout-grid is-layout-grid-3">            
            {currentPosts.map(post => (
                <li>
                    <div class="post-card">
                        <h2>
                            <a href={`/posts/${post.data.slug}/`}>{post.data.title}</a>
                        </h2>     
                        <div>
                          <div class="post-meta">
                              <span>{formatDate(post.data.date)}</span> — by <a href={`/author/${post.data.author?.toLowerCase().replace(/\s+/g, '-')}/`}>{post.data.author}</a> in <a href={`/categories/${categorySlug}/`}>{categoryName}</a>
                          </div> 
                          <div>
                              <p class="post-excerpt">
                                  {getExcerpt(post.body ?? "", 55)}
                              </p>
                              <p style="margin-top: 1.2rem;"> 
                                  <a href={`/posts/${post.data.slug}`}>read more</a>
                              </p>
                          </div>
                        </div>
                    </div>
                </li>
            ))}            
        </ul>
        <Pagination currentPage={currentPage} totalPages={totalPages}  baseUrl={`/categories/${categorySlug}/`} />
    </div>
</BaseLayout>
