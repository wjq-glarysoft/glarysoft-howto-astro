---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getExcerpt } from '../utils/truncate';
import Pagination from '../components/Pagination.astro';

// 首页直接显示第一页的内容
const POSTS_PER_PAGE = 80;
const currentPage = 1;

// 获取所有文章并排序
const allPosts = (await getCollection('posts'))
  .map(post => ({
    ...post
  })).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// 计算总页数
const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);

// 获取第一页的文章
const startIndex = 0;
const currentPosts = allPosts.slice(startIndex, startIndex + POSTS_PER_PAGE);

---

<BaseLayout title="Glarysoft How-to Articles">
  <div class="container" style="margin-top: 1.2rem;">
    <div>
      <p class="block-spacer-50"></p>
      <h1 style="text-align: center; margin-top: 1.2rem;">How to Articles</h1>
      <p class="block-spacer-30"></p>
    </div>
    
    <div style="margin-top: 1.2rem;">
      <ul class="is-layout-grid">
        {currentPosts.map((post) => (
          <li>
            <div class="post-card">
              <h2>
                <a href={`/posts/${post.data.slug}`}>
                  {post.data.title || 'Untitled'}
                </a>
              </h2>
              <div>
                <p class="post-excerpt">
                  {getExcerpt(post.body ?? "", 55)}
                </p>
                <p style="margin-top: 1.2rem;">
                  <a href={`/posts/${post.data.slug}`}>read more</a>
                </p>
              </div>
            </div>
          </li>
        ))}
      </ul>
      
      <!-- 分页导航组件 -->
      <Pagination currentPage={currentPage} totalPages={totalPages} />
    </div>
  </div>
</BaseLayout>

